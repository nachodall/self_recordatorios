// Reminders — Prisma schema
// Dev: SQLite. Para deploy (fase 2) cambiar provider a "postgresql".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Reminder {
  id        String    @id @default(cuid())
  text      String
  remindAt  DateTime
  createdAt DateTime  @default(now())
  sentAt    DateTime? // null = todavía no notificado

  @@index([remindAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
